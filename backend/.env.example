# MAXIA V12 — Environment Variables
# Copy this to .env and fill in your values

GROQ_API_KEY=your_groq_key
CEREBRAS_API_KEY=your_cerebras_key
CEREBRAS_MODEL=gpt-oss-120b
GOOGLE_AI_KEY=your_google_ai_key
GOOGLE_AI_MODEL=gemini-2.5-flash-lite
RUNPOD_API_KEY=your_runpod_key
HELIUS_API_KEY=your_helius_key
ANTHROPIC_API_KEY=your_anthropic_key
TREASURY_ADDRESS=your_treasury_wallet
ESCROW_ADDRESS=your_escrow_wallet
ESCROW_PRIVKEY_B58=your_escrow_private_key
MARKETING_WALLET_ADDRESS=your_marketing_wallet
MARKETING_WALLET_PRIVKEY=your_marketing_private_key
MICRO_WALLET_ADDRESS=your_micro_wallet
MICRO_WALLET_PRIVKEY=your_micro_private_key
DISCORD_WEBHOOK_URL=your_discord_webhook
DISCORD_BOT_TOKEN=your_discord_bot_token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
ADMIN_KEY=your_admin_password
BROKER_MARGIN=1.00
GITHUB_TOKEN=your_github_token
GITHUB_ORG=MAXIA-AI
GITHUB_REPO=site
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_SECRET=your_twitter_access_secret

# Finnhub (stock price oracle fallback — free tier: 60 req/min)
FINNHUB_API_KEY=your_finnhub_key

# Reddit Bot (account must be 30+ days old)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password

# TON (The Open Network) — non-EVM
TON_API_URL=https://toncenter.com/api/v2
TREASURY_ADDRESS_TON=your_ton_treasury_address

# SUI — non-EVM
SUI_RPC=https://fullnode.mainnet.sui.io:443
TREASURY_ADDRESS_SUI=your_sui_treasury_address

# LlamaIndex Cloud (for LlamaHub submission)
LLAMAINDEX_API_KEY=your_llamaindex_key

# Bitcoin (on-chain + Lightning)
TREASURY_ADDRESS_BITCOIN=your_btc_address
LNBOT_API_KEY=your_lnbot_wallet_key_wk
LNBOT_WALLET_ID=your_lnbot_wallet_id_wal

# Vercel Integration
VERCEL_CLIENT_ID=your_vercel_client_id
VERCEL_CLIENT_SECRET=your_vercel_client_secret
