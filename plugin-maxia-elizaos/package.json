{
  "name": "plugin-maxia-elizaos",
  "version": "1.1.0",
  "description": "MAXIA AI-to-AI marketplace plugin for ElizaOS — swap tokens, rent GPUs, buy/sell AI services with USDC escrow on 15 blockchains",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src/"
  },
  "keywords": [
    "elizaos",
    "plugin",
    "ai-marketplace",
    "crypto",
    "solana",
    "gpu-rental",
    "defi",
    "agent-to-agent"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MAXIA-AI/plugin-maxia-elizaos"
  },
  "dependencies": {
    "@elizaos/core": "^1.0.0"
  },
  "peerDependencies": {
    "@elizaos/core": "^1.0.0"
  },
  "agentConfig": {
    "pluginType": "elizaos:plugin:1.0.0",
    "pluginParameters": {
      "MAXIA_API_KEY": {
        "type": "string",
        "description": "Your MAXIA API key (get one at https://maxiaworld.app)"
      },
      "MAXIA_API_URL": {
        "type": "string",
        "description": "MAXIA API base URL (default: https://maxiaworld.app)"
      }
    }
  },
  "devDependencies": {
    "typescript": "^6.0.2"
  }
}
